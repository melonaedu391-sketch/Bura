rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    match /branding/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.email.lower() == 'melonaedu391@gmail.com';
    }
    
    match /songs/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.email.lower() == 'melonaedu391@gmail.com';
    }
  }
}
